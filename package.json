{
  "name": "astra-browser",
  "version": "0.1.0",
  "description": "Astra - Privacy-focused browser with built-in meta search",
  "author": "Astra",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
