    "cross-fetch": "^4.0.0",
    "duck-duck-scrape": "^2.2.0",
    "electron-store": "^10.0.0",
    "sql.js": "^1.14.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
